# ──────────────────────────────────────────────────────────────────────
#  PDFRAG — Environment configuration
#  Copy this file to `.env` and fill in your Azure OpenAI credentials.
#  `.env` is git-ignored; never commit real keys.
# ──────────────────────────────────────────────────────────────────────

# ── Azure OpenAI (REQUIRED) ──
AZURE_ENDPOINT    = "https://<your-resource>.openai.azure.com/"
AZURE_API_KEY     = "<your-azure-openai-key>"
AZURE_API_VERSION = "2025-01-01-preview"
EMBEDDING_MODEL   = "text-embedding-ada-002"
CHAT_MODEL        = "gpt-4.1"

# ── Chunking (REQUIRED) ──
CHUNK_SIZE        = 1000
CHUNK_OVERLAP     = 300

# ── Retrieval (optional; defaults shown) ──
TOP_K                     = 5
EMBEDDING_BATCH_SIZE      = 50
DOC_RELEVANCE_THRESHOLD   = 0.25
CHUNK_RELEVANCE_THRESHOLD = 0.20

# ── Uploads (optional) ──
# Max size in MB accepted for a single uploaded file.
MAX_UPLOAD_MB             = 50

# ── Semantic chunker tuning (optional) ──
SEMANTIC_BREAKPOINT_THRESHOLD = 0.3
SEMANTIC_MIN_CHUNK_SIZE       = 100
SEMANTIC_MAX_CHUNK_SIZE       = 1000

# ── Vision: math transcription fallback (optional) ──
VISION_ENABLED     = true
VISION_MODEL       = gpt-4.1
VISION_DPI         = 200
VISION_MAX_WORKERS = 8

# ── Vision: figure/diagram captioning (optional) ──
VISION_CAPTION_FIGURES = true
FIGURE_MIN_WIDTH       = 60
FIGURE_MIN_HEIGHT      = 50
FIGURE_MAX_PER_PAGE    = 6
